</Layout>

<script>
	function initAnimations() {
		// === BOOT SCREEN ===
		const bootScreen = document.getElementById('boot-screen');
		const bootLines = document.querySelectorAll('.boot-line');

		bootLines.forEach((line) => {
			const delay = parseInt(line.getAttribute('data-delay') || '0');
			setTimeout(() => {
				(line as HTMLElement).classList.add('visible');
			}, delay);
		});

		setTimeout(() => {
			bootScreen?.classList.add('fade-out');
			document.body.classList.add('booted');
			setTimeout(() => {
				bootScreen?.remove();
				initScrollAnimations();
				initTypingAnimations();
				initCountUp();
			}, 500);
		}, 2000);

		// === SCROLL REVEAL ===
		function initScrollAnimations() {
			const reveals = document.querySelectorAll('.reveal');

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							const delay = parseInt(entry.target.getAttribute('data-delay') || '0');
							setTimeout(() => {
								entry.target.classList.add('visible');
							}, delay);
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.1 }
			);

			reveals.forEach((el) => observer.observe(el));

			// === POP-IN (skill tags) ===
			const popIns = document.querySelectorAll('.pop-in');

			const popObserver = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							const delay = parseInt(entry.target.getAttribute('data-delay') || '0');
							setTimeout(() => {
								entry.target.classList.add('visible');
							}, delay);
							popObserver.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.1 }
			);

			popIns.forEach((el) => popObserver.observe(el));
		}

		// === TYPING ANIMATION ===
		function initTypingAnimations() {
			const typeLines = document.querySelectorAll('.type-line');

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting && !entry.target.classList.contains('typed')) {
							entry.target.classList.add('typed');
							const target = entry.target.querySelector('.type-target');
							if (!target) return;
							const fullText = target.textContent || '';
							target.textContent = '';
							let i = 0;
							const type = () => {
								if (i < fullText.length) {
									target.textContent += fullText[i];
									i++;
									setTimeout(type, 40 + Math.random() * 30);
								}
							};
							type();
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.5 }
			);

			typeLines.forEach((el) => observer.observe(el));
		}

		// === COUNT UP ===
		function initCountUp() {
			const counters = document.querySelectorAll('[data-count]');

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting && !entry.target.classList.contains('counted')) {
							entry.target.classList.add('counted');
							const el = entry.target as HTMLElement;
							const target = parseInt(el.getAttribute('data-count') || '0');
							const duration = 1500;
							const step = target / (duration / 16);
							let current = 0;

							const update = () => {
								current += step;
								if (current >= target) {
									el.textContent = String(target);
									return;
								}
								el.textContent = String(Math.floor(current));
								requestAnimationFrame(update);
							};
							requestAnimationFrame(update);
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.5 }
			);

			counters.forEach((el) => observer.observe(el));
		}
	}

	document.addEventListener('DOMContentLoaded', initAnimations);
</script>

<style>
	.main-content {
		margin-left: var(--sidebar-width);
		min-height: 100vh;
	}

	/* === BOOT SCREEN === */
	.boot-screen {
		position: fixed;
		inset: 0;
		z-index: 9999;
		background: #000;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: opacity 0.5s ease, visibility 0.5s ease;
	}

	.boot-screen.fade-out {
		opacity: 0;
		visibility: hidden;
	}

	.boot-lines {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--green-dark);
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.boot-line {
		opacity: 0;
		transform: translateY(4px);
		transition: all 0.3s ease;
	}

	.boot-line.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.boot-line.ready {
		color: var(--green);
		font-weight: 600;
		text-shadow: 0 0 10px var(--green-glow);
	}

	/* === SCANLINE === */
	.scanline-overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 50;
		background: repeating-linear-gradient(
			0deg,
			var(--scanline) 0px,
			var(--scanline) 1px,
			transparent 1px,
			transparent 2px
		);
	}

	/* === REVEAL ANIMATION === */
	.reveal {
		opacity: 0;
		transform: translateY(var(--space-xl));
		transition: opacity var(--duration-slowest) var(--ease-default), transform var(--duration-slowest) var(--ease-default);
	}

	.reveal.visible {
		opacity: 1;
		transform: translateY(0);
	}

	/* === POP IN === */
	.pop-in {
		opacity: 0;
		transform: scale(0.8) translateY(var(--space-sm));
		transition: opacity var(--duration-slower) var(--ease-default), transform var(--duration-slower) var(--ease-default);
	}

	.pop-in.visible {
		opacity: 1;
		transform: scale(1) translateY(0);
	}

	/* === HERO === */
	.hero-section {
		min-height: 100vh;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		gap: var(--space-xl);
		max-width: 800px;
	}

	.terminal-window {
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
		background: var(--bg-card);
	}

	.terminal-bar {
		padding: var(--space-sm) var(--space-md);
		background: rgba(0, 255, 65, 0.03);
		border-bottom: 1px solid var(--border);
		font-size: var(--text-xs);
		color: var(--text-dim);
	}

	.terminal-body {
		padding: var(--space-lg);
	}

	.terminal-line {
		font-size: var(--text-sm);
		color: var(--text-dim);
		margin-bottom: var(--space-sm);
	}

	.prompt-symbol {
		color: var(--green);
		margin-right: var(--space-sm);
	}

	.type-target {
		color: var(--text-dim);
	}

	.type-line.typed .type-target::after {
		content: '|';
		color: var(--green);
		animation: blink 1s step-end infinite;
		margin-left: 2px;
	}

	.hero-content h1 {
		font-size: clamp(2.5rem, 6vw, 4rem);
		font-weight: 700;
		color: var(--green);
		line-height: 1.1;
