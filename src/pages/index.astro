---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import MatrixRain from '../components/MatrixRain.astro';
import { BoltIcon, LockIcon, ChartIcon, GlobeIcon } from '../components/ProjectIcon';
import { GithubIcon, LinkedinIcon, TwitterIcon, EmailIcon } from '../components/ContactIcon';
---

<Layout title="root@portfolio:~">
	<MatrixRain />
	<Sidebar />
	<div class="scanline-overlay"></div>

	<!-- BOOT SCREEN -->
	<div class="boot-screen" id="boot-screen">
		<div class="boot-lines">
			<p class="boot-line" data-delay="0">[ OK ] Starting system...</p>
			<p class="boot-line" data-delay="200">[ OK ] Loading kernel modules...</p>
			<p class="boot-line" data-delay="400">[ OK ] Mounting filesystems...</p>
			<p class="boot-line" data-delay="600">[ OK ] Starting network services...</p>
			<p class="boot-line" data-delay="800">[ OK ] Initializing portfolio v3.0...</p>
			<p class="boot-line" data-delay="1000">[ OK ] Loading developer profile...</p>
			<p class="boot-line ready" data-delay="1300">&gt; system ready_</p>
		</div>
	</div>

	<main class="main-content">
		<!-- 01: HOME -->
		<section id="home" class="section hero-section">
			<div class="hero-content">
				<div class="terminal-window reveal">
					<div class="terminal-bar">
						<span class="terminal-title">root@portfolio:~</span>
					</div>
					<div class="terminal-body">
						<p class="terminal-line type-line" data-text="$ whoami">
							<span class="prompt-symbol">$</span>
							<span class="type-target">whoami</span>
						</p>
						<h1 class="glitch" data-text="John Doe">John Doe</h1>
						<p class="terminal-line type-line" data-text="$ cat role.txt">
							<span class="prompt-symbol">$</span>
							<span class="type-target">cat role.txt</span>
						</p>
						<p class="role-text">
							Full Stack Developer <span class="cursor">_</span>
						</p>
						<p class="terminal-line mt-sm type-line" data-text="$ cat motto.txt">
							<span class="prompt-symbol">$</span>
							<span class="type-target">cat motto.txt</span>
						</p>
						<p class="motto-text">
							// building things that break the internet (in a good way)
						</p>
						<div class="hero-cta">
							<a href="#projects" class="btn-primary">
								<span>[</span> explore projects <span>]</span>
							</a>
							<a href="#contact" class="btn-secondary">
								<span>[</span> contact me <span>]</span>
							</a>
						</div>
					</div>
				</div>
				<div class="ascii-art reveal" data-delay="400">
<pre class="ascii-block">
    _    ____ _____ _   _ ______   __
   / \  |  _ \ ____| \ | |  _ \ \ / /
  / _ \ | |_) |  _| |  \| | | | \ V /
 / ___ \|  __/| |___| |\  | |_| || |
/_/   \_\_|   |_____|_| \_|____/ |_|
</pre>
				</div>
			</div>
		</section>

		<!-- 02: ABOUT -->
		<section id="about" class="section">
			<span class="section-label reveal">// section 02</span>
			<h2 class="section-title reveal" data-delay="100">about<span class="cursor">_</span></h2>
			<div class="about-grid">
				<div class="about-text">
					<p class="terminal-line type-line reveal" data-delay="200" data-text="$ cat about.md">
						<span class="prompt-symbol">$</span>
						<span class="type-target">cat about.md</span>
					</p>
					<div class="content-block reveal" data-delay="300">
						<p>
							Developer yang passionate dalam membangun produk digital.
							Fokus di full-stack development dengan pengalaman di
