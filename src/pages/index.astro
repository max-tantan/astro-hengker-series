						<span class="card-icon"><LockIcon client:load /></span>
						<div class="card-links">
							<a href="#" class="card-link">source</a>
							<a href="#" class="card-link">live ↗</a>
						</div>
					</div>
					<h3 class="card-title">cryptovault</h3>
