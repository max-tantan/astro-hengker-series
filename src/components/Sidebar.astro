---
const sections = [
	{ id: 'home', label: '~/home', icon: '>' },
	{ id: 'about', label: '~/about', icon: '>' },
	{ id: 'skills', label: '~/skills', icon: '>' },
	{ id: 'projects', label: '~/projects', icon: '>' },
	{ id: 'experience', label: '~/experience', icon: '>' },
	{ id: 'contact', label: '~/contact', icon: '>' },
];
---

<aside class="sidebar" id="sidebar">
	<div class="sidebar-header">
		<div class="logo">
			<span class="prompt">$</span> <span class="user">root</span><span class="at">@</span><span class="host">portfolio</span>
		</div>
		<div class="terminal-dot">
			<span class="dot red"></span>
			<span class="dot yellow"></span>
			<span class="dot green"></span>
		</div>
	</div>

	<div class="profile">
		<div class="avatar-wrapper">
			<div class="avatar-ring">
				<div class="avatar-ring-segment top"></div>
				<div class="avatar-ring-segment right"></div>
				<div class="avatar-ring-segment bottom"></div>
				<div class="avatar-ring-segment left"></div>
			</div>
			<div class="avatar-container">
				<img src="/avatar.jpg" alt="profile photo" class="avatar-img" />
				<div class="avatar-overlay">
					<div class="scanline-bar"></div>
				</div>
				<div class="avatar-glitch-r"></div>
				<div class="avatar-glitch-b"></div>
				<div class="avatar-hex">
					<div class="hex-line">4A 2B 8C</div>
					<div class="hex-line">1D 3E 5F</div>
					<div class="hex-line">6A 7B 9C</div>
				</div>
			</div>
			<div class="avatar-pulse"></div>
			<div class="avatar-pulse delay"></div>
		</div>
		<div class="profile-info">
			<span class="profile-name">John Doe</span>
			<span class="profile-role">root@sys:~#</span>
		</div>
	</div>

	<nav class="nav">
		{sections.map((s, i) => (
			<a href={`#${s.id}`} class="nav-link" data-section={s.id}>
				<span class="nav-index">0{i + 1}</span>
				<span class="nav-icon">{s.icon}</span>
				<span class="nav-label">{s.label}</span>
				<span class="nav-arrow">/</span>
			</a>
		))}
	</nav>

	<div class="sidebar-footer">
		<div class="status-line">
			<span class="blink-dot"></span>
			<span>system online</span>
		</div>
		<div class="path-info">pwd: ~/portfolio</div>
	</div>
</aside>

<button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle menu">
	<span class="bar"></span>
	<span class="bar"></span>
	<span class="bar"></span>
</button>

<script>
	function initSidebar() {
		const links = document.querySelectorAll('.nav-link');
		const toggle = document.getElementById('mobile-toggle');
		const sidebar = document.getElementById('sidebar');
		const sections = document.querySelectorAll('.section');

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const id = entry.target.getAttribute('id');
						links.forEach((link) => {
							link.classList.toggle('active', link.getAttribute('data-section') === id);
						});
					}
				});
			},
			{ threshold: 0.4 }
		);

		sections.forEach((section) => observer.observe(section));

		toggle?.addEventListener('click', () => {
			sidebar?.classList.toggle('open');
			toggle.classList.toggle('active');
		});

		links.forEach((link) => {
			link.addEventListener('click', () => {
				sidebar?.classList.remove('open');
				toggle?.classList.remove('active');
			});
		});
	}

	document.addEventListener('DOMContentLoaded', initSidebar);
</script>

<style>
	.sidebar {
		position: fixed;
		top: 0;
		left: 0;
		width: var(--sidebar-width);
		height: 100vh;
		background: var(--bg-sidebar);
		border-right: 1px solid var(--border);
		display: flex;
		flex-direction: column;
		z-index: 100;
		overflow-y: auto;
		transition: transform 0.3s ease;
	}

	.sidebar::before {
		content: '';
		position: absolute;
		top: 0;
		right: 0;
		width: 1px;
		height: 100%;
		background: linear-gradient(
			to bottom,
			transparent,
			var(--green-dark),
			var(--green-dim),
			var(--green-dark),
			transparent
		);
	}

	.sidebar-header {
		padding: 24px 20px;
		border-bottom: 1px solid var(--border);
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo {
		font-size: 0.8rem;
		font-weight: 600;
	}

	.prompt {
		color: var(--green);
	}

	.user {
		color: var(--green-dim);
	}

	.at {
		color: var(--text-dim);
	}

	.host {
		color: var(--text-primary);
	}

	.terminal-dot {
		display: flex;
		gap: 6px;
	}

	.dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		opacity: 0.8;
	}

	.dot.red { background: #ff5f56; }
	.dot.yellow { background: #ffbd2e; }
	.dot.green { background: #27c93f; }

	/* PROFILE */
	.profile {
		padding: 24px 20px 20px;
		display: flex;
		flex-direction: column;
		align-items: center;
		border-bottom: 1px solid var(--border);
	}

	.avatar-wrapper {
		position: relative;
		width: 100px;
		height: 100px;
		margin-bottom: 14px;
	}

	.avatar-ring {
		position: absolute;
		inset: -4px;
		border-radius: 50%;
	}

	.avatar-ring-segment {
		position: absolute;
		background: var(--green-dark);
		transition: background 0.3s ease, box-shadow 0.3s ease;
	}

	.avatar-ring-segment.top {
		top: 0; left: 50%; transform: translateX(-50%);
		width: 40px; height: 2px;
	}

	.avatar-ring-segment.bottom {
		bottom: 0; left: 50%; transform: translateX(-50%);
		width: 40px; height: 2px;
	}

	.avatar-ring-segment.left {
		left: 0; top: 50%; transform: translateY(-50%);
		width: 2px; height: 40px;
	}

	.avatar-ring-segment.right {
		right: 0; top: 50%; transform: translateY(-50%);
		width: 2px; height: 40px;
	}

	.avatar-wrapper:hover .avatar-ring-segment {
		background: var(--green);
		box-shadow: 0 0 8px var(--green-glow);
	}

	.avatar-container {
		width: 100px;
		height: 100px;
		border-radius: 50%;
		overflow: hidden;
		position: relative;
		border: 2px solid var(--green-dark);
		transition: border-color 0.3s ease;
	}

	.avatar-wrapper:hover .avatar-container {
		border-color: var(--green);
	}

	.avatar-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: grayscale(60%) brightness(0.7) contrast(1.2);
		transition: filter 0.4s ease;
	}

	.avatar-wrapper:hover .avatar-img {
		filter: grayscale(0%) brightness(0.9) contrast(1.1);
	}

	.avatar-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			180deg,
			transparent 0%,
			rgba(0, 255, 65, 0.03) 50%,
			transparent 100%
		);
		pointer-events: none;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.avatar-wrapper:hover .avatar-overlay {
		opacity: 1;
	}

	.scanline-bar {
		position: absolute;
		left: 0;
		width: 100%;
		height: 2px;
		background: rgba(0, 255, 65, 0.4);
		box-shadow: 0 0 10px var(--green-glow);
		animation: scanline 2s linear infinite;
		opacity: 0;
	}

	.avatar-wrapper:hover .scanline-bar {
		opacity: 1;
	}

	.avatar-glitch-r,
	.avatar-glitch-b {
		position: absolute;
		inset: 0;
		border-radius: 50%;
		opacity: 0;
		pointer-events: none;
		mix-blend-mode: screen;
	}

	.avatar-glitch-r {
		background: rgba(255, 0, 64, 0.3);
	}

	.avatar-glitch-b {
		background: rgba(0, 255, 255, 0.3);
	}

	.avatar-wrapper:hover .avatar-glitch-r {
		opacity: 0.4;
		animation: glitch 2s infinite;
		clip-path: inset(20% 0 60% 0);
	}

	.avatar-wrapper:hover .avatar-glitch-b {
		opacity: 0.4;
		animation: glitch 2s infinite reverse;
		clip-path: inset(50% 0 10% 0);
	}

	.avatar-hex {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2px;
		opacity: 0;
		transition: opacity 0.3s ease;
		background: rgba(0, 0, 0, 0.7);
	}

	.avatar-wrapper:hover .avatar-hex {
		opacity: 1;
	}

	.hex-line {
		font-size: 0.55rem;
		color: var(--green);
		letter-spacing: 2px;
		text-shadow: 0 0 6px var(--green-glow);
	}

	.avatar-pulse {
		position: absolute;
		inset: -6px;
		border-radius: 50%;
		border: 1px solid var(--green-dark);
		opacity: 0;
		pointer-events: none;
	}

	.avatar-wrapper:hover .avatar-pulse {
		animation: pulse-ring 1.5s ease-out infinite;
	}

	.avatar-wrapper:hover .avatar-pulse.delay {
		animation-delay: 0.5s;
	}

	@keyframes pulse-ring {
		0% {
			transform: scale(1);
			opacity: 0.6;
		}
		100% {
			transform: scale(1.4);
			opacity: 0;
		}
	}

	.profile-info {
		text-align: center;
	}

	.profile-name {
		display: block;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--text-primary);
		margin-bottom: 2px;
	}

	.profile-role {
		font-size: 0.65rem;
		color: var(--green-dark);
		letter-spacing: 1px;
	}

	.nav {
		flex: 1;
		padding: 16px 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.nav-link {
		display: flex;
		align-items: center;
		padding: 10px 20px;
		font-size: 0.78rem;
		color: var(--text-dim);
		text-decoration: none;
		transition: all 0.25s ease;
		position: relative;
		gap: 8px;
	}

	.nav-link::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0;
		width: 2px;
		height: 100%;
		background: var(--green);
		transform: scaleY(0);
		transition: transform 0.25s ease;
	}

	.nav-link:hover {
		color: var(--green);
		background: var(--green-subtle);
	}

	.nav-link:hover::before {
		transform: scaleY(1);
	}

	.nav-link.active {
		color: var(--green);
		background: rgba(0, 255, 65, 0.08);
	}

	.nav-link.active::before {
		transform: scaleY(1);
		box-shadow: 0 0 10px var(--green-glow);
	}

	.nav-link.active .nav-index {
		color: var(--green);
	}

	.nav-index {
		font-size: 0.65rem;
		color: var(--green-dark);
		min-width: 20px;
		transition: color 0.25s ease;
	}

	.nav-icon {
		color: var(--green-dark);
		font-weight: 700;
	}

	.nav-label {
		flex: 1;
	}

	.nav-arrow {
		color: var(--green-dark);
		opacity: 0;
		transform: translateX(-4px);
		transition: all 0.25s ease;
	}

	.nav-link:hover .nav-arrow,
	.nav-link.active .nav-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	.sidebar-footer {
		padding: 16px 20px;
		border-top: 1px solid var(--border);
		font-size: 0.65rem;
		color: var(--text-dim);
	}

	.status-line {
		display: flex;
		align-items: center;
		gap: 8px;
		margin-bottom: 6px;
	}

	.blink-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--green);
		animation: blink 2s step-end infinite;
	}

	.path-info {
		color: var(--green-dark);
	}

	.mobile-toggle {
		display: none;
		position: fixed;
		top: 16px;
		left: 16px;
		z-index: 200;
		background: var(--bg-sidebar);
		border: 1px solid var(--border);
		padding: 10px;
		cursor: pointer;
		flex-direction: column;
		gap: 4px;
	}

	.bar {
		width: 20px;
		height: 2px;
		background: var(--green);
		transition: all 0.3s ease;
	}

	.mobile-toggle.active .bar:nth-child(1) {
		transform: rotate(45deg) translate(4px, 4px);
	}

	.mobile-toggle.active .bar:nth-child(2) {
		opacity: 0;
	}

	.mobile-toggle.active .bar:nth-child(3) {
		transform: rotate(-45deg) translate(4px, -4px);
	}

	@media (max-width: 768px) {
		.sidebar {
			transform: translateX(-100%);
		}

		.sidebar.open {
			transform: translateX(0);
			box-shadow: 4px 0 30px rgba(0, 0, 0, 0.8);
		}

		.mobile-toggle {
			display: flex;
		}
	}
</style>
