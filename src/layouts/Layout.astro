---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		/* Colors — Brand */
		--green: #00ff41;
		--green-dim: #00cc33;
		--green-dark: #008f11;
		--green-glow: rgba(0, 255, 65, 0.3);
		--green-subtle: rgba(0, 255, 65, 0.05);

		/* Colors — Background */
		--bg-primary: #0a0a0a;
		--bg-secondary: #0d0d0d;
		--bg-sidebar: #080808;
		--bg-card: rgba(0, 255, 65, 0.03);
		--bg-card-hover: rgba(0, 255, 65, 0.05);
		--bg-active: rgba(0, 255, 65, 0.08);

		/* Colors — Border */
		--border: rgba(0, 255, 65, 0.1);
		--border-hover: rgba(0, 255, 65, 0.25);

		/* Colors — Text */
		--text-primary: #b0ffb0;
		--text-dim: #3a7a3a;

		/* Colors — Dots (terminal) */
		--dot-red: #ff5f56;
		--dot-yellow: #ffbd2e;
		--dot-green: #27c93f;

		/* Colors — Glitch */
		--glitch-red: rgba(255, 0, 64, 0.3);
		--glitch-cyan: rgba(0, 255, 255, 0.3);

		/* Colors — Scanline */
		--scanline: rgba(0, 0, 0, 0.03);
		--scanline-bar: rgba(0, 255, 65, 0.4);

		/* Colors — Shadows */
		--shadow-sidebar: rgba(0, 0, 0, 0.8);

		/* Spacing Scale */
		--space-2xs: 2px;
		--space-xs: 4px;
		--space-sm: 8px;
		--space-md: 12px;
		--space-base: 16px;
		--space-lg: 20px;
		--space-xl: 24px;
		--space-2xl: 28px;
		--space-3xl: 32px;
		--space-4xl: 40px;
		--space-5xl: 48px;
		--space-6xl: 60px;
		--space-section: 80px;

		/* Shadows */
		--shadow-sm: 0 0 8px var(--green-glow);
		--shadow-md: 0 0 15px rgba(0, 255, 65, 0.05);
		--shadow-lg: 0 0 20px var(--green-glow);
		--shadow-card: 0 4px 30px rgba(0, 255, 65, 0.05);
		--shadow-sidebar-mobile: 4px 0 30px var(--shadow-sidebar);

		/* Motion */
		--duration-fast: 0.2s;
		--duration-normal: 0.25s;
		--duration-slow: 0.3s;
		--duration-slower: 0.4s;
		--duration-slowest: 0.6s;
		--ease-default: ease;
		--ease-out: ease-out;
		--ease-in-out: ease-in-out;

		/* Typography */
		--font-mono: 'Fira Code', 'Share Tech Mono', ui-monospace, 'Cascadia Code', monospace;
		--text-xs: 0.65rem;
		--text-sm: 0.7rem;
		--text-base: 0.78rem;
		--text-md: 0.85rem;
		--text-lg: 0.95rem;
		--text-xl: 1.1rem;
		--text-2xl: clamp(1.8rem, 4vw, 2.8rem);
		--text-hero: clamp(2.5rem, 6vw, 4rem);

		/* Layout */
		--sidebar-width: 260px;
		--avatar-size: 100px;
		--avatar-ring-gap: 4px;
		--avatar-segment: 40px;
		--dot-size: 8px;
		--cursor-width: 2px;
		--scrollbar-width: 6px;
		--section-title-underline: 60px;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
		scroll-padding-top: 0;
	}

	body {
		font-family: var(--font-mono);
		background: var(--bg-primary);
		color: var(--text-primary);
		line-height: 1.7;
		overflow-x: hidden;
		min-height: 100vh;
	}

	::selection {
		background: var(--green);
		color: var(--bg-primary);
	}

	::-webkit-scrollbar {
		width: var(--scrollbar-width);
	}

	::-webkit-scrollbar-track {
		background: var(--bg-primary);
	}

	::-webkit-scrollbar-thumb {
		background: var(--green-dark);
		border-radius: 3px;
	}

	::-webkit-scrollbar-thumb:hover {
		background: var(--green-dim);
	}

	a {
		color: var(--green);
		text-decoration: none;
		transition: all var(--duration-fast) var(--ease-default);
	}

	a:hover {
		text-shadow: var(--shadow-sm);
	}

	/* React Icons */
	[class*="react-icons"] svg,
	svg.icon-svg {
		color: var(--green);
		fill: currentColor;
		vertical-align: middle;
	}

	@keyframes blink {
		0%, 50% { opacity: 1; }
		51%, 100% { opacity: 0; }
	}

	@keyframes glitch {
		0% { transform: translate(0); }
		20% { transform: translate(-2px, 2px); }
		40% { transform: translate(-2px, -2px); }
		60% { transform: translate(2px, 2px); }
		80% { transform: translate(2px, -2px); }
		100% { transform: translate(0); }
	}

	@keyframes scanline {
		0% { top: -100%; }
		100% { top: 100%; }
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes typing {
		from { width: 0; }
		to { width: 100%; }
	}

	.section {
		min-height: 100vh;
		padding: var(--space-section) var(--space-6xl) var(--space-section) var(--space-6xl);
		display: flex;
		flex-direction: column;
		justify-content: center;
		position: relative;
	}

	.section-label {
		font-size: var(--text-sm);
		color: var(--green-dark);
		text-transform: uppercase;
		letter-spacing: var(--space-4xl);
		margin-bottom: var(--space-sm);
	}

	.section-title {
		font-size: var(--text-2xl);
		color: var(--green);
		font-weight: 700;
		margin-bottom: var(--space-4xl);
		position: relative;
		display: inline-block;
		width: fit-content;
	}

	.section-title::after {
		content: '';
		position: absolute;
		bottom: -8px;
		left: 0;
		width: var(--section-title-underline);
		height: 2px;
		background: var(--green);
		box-shadow: var(--shadow-sm);
	}

	.section-title .cursor {
		display: inline-block;
		width: var(--cursor-width);
		height: 1em;
		background: var(--green);
		margin-left: var(--space-xs);
		animation: blink 1s step-end infinite;
		vertical-align: text-bottom;
	}

	@media (max-width: 768px) {
		.section {
			padding: var(--space-6xl) var(--space-lg);
		}
	}
</style>
